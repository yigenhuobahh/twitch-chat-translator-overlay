# 翻译 API 配置（只有自动翻译需要）
# 复制本文件为 .env，填入你的 API 信息
# 也可以直接设置环境变量（PowerShell: $env:OPENAI_COMPAT_BASE_URL="...")
#
# 不翻译只想看英文弹幕？加 --render-original 即可，本文件可以不配。
#
# 支持任何 OpenAI-compatible 接口，例如:
#   OpenAI:     https://api.openai.com/v1
#   DeepSeek:   https://api.deepseek.com/v1
#   Moonshot:   https://api.moonshot.cn/v1
#   本地 Ollama: http://localhost:11434/v1

OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_MODEL=
OPENAI_COMPAT_API_KEY=

# Optional legacy aliases (used only when OPENAI_COMPAT_* is empty)
# AGNES_BASE_URL=
# AGNES_MODEL=
# AGNES_API_KEY=
